{
  "name": "manifoldpowered.com",
  "version": "1.0.0",
  "description": "🌍 **Idioma:** Português (Brasil) | [English](./README.md)",
  "homepage": "https://github.com/pedromello/manifoldpowered.com#readme",
  "bugs": {
    "url": "https://github.com/pedromello/manifoldpowered.com/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pedromello/manifoldpowered.com.git"
  },
  "license": "ISC",
  "author": "Pedro Mello",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "npm run services:up && npm run services:wait:database && npm run prisma:generate && npm run migrate:dev && next dev",
    "test": "npm run services:up && npm run prisma:generate && npm run migrate:dev && concurrently -n next,jest -k -s command-jest \"next dev\" \"jest --runInBand\"",
    "posttest": "npm run services:down",
    "test:watch": "jest --watchAll --runInBand --verbose",
    "services:up": "docker compose -f infra/compose.yaml up -d",
    "services:stop": "docker compose -f infra/compose.yaml stop",
    "services:down": "docker compose -f infra/compose.yaml down",
    "services:wait:database": "node infra/scripts/wait-for-postgres.js",
    "migrate:deploy": "npx prisma migrate deploy",
    "migrate:dev": "npx prisma migrate dev",
    "migrate:create": "npx prisma migrate dev --create-only",
    "prisma:generate": "npx prisma generate",
    "build": "next build",
    "lint:prettier:check": "prettier --check .",
    "lint:prettier:fix": "prettier --write .",
    "lint:eslint:check": "eslint .",
    "lint:eslint:fix": "eslint . --fix",
    "prepare": "husky",
    "commit": "cz"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.7.0",
    "@prisma/client": "7.7.0",
    "@tabler/icons-react": "3.41.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@vercel/analytics": "^2.0.1",
    "async-retry": "1.3.3",
    "bcryptjs": "3.0.3",
    "cookie": "1.1.1",
    "lucide-react": "1.8.0",
    "next": "16.2.3",
    "next-connect": "1.0.0",
    "nodemailer": "8.0.5",
    "pg": "8.20.0",
    "postcss": "^8.5.9",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-markdown": "10.1.0",
    "rehype-raw": "7.0.0",
    "remark-gfm": "4.0.1",
    "set-cookie-parser": "3.1.0",
    "swr": "2.4.1",
    "tailwindcss": "^4.2.2",
    "uuid": "13.0.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@faker-js/faker": "10.4.0",
    "@types/jest": "30.0.0",
    "@types/node": "25.5.2",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.14",
    "commitizen": "4.3.1",
    "concurrently": "9.2.1",
    "cz-conventional-changelog": "3.3.0",
    "dotenv": "17.4.1",
    "dotenv-expand": "12.0.3",
    "eslint": "9.39.3",
    "eslint-config-next": "16.2.3",
    "husky": "9.1.7",
    "jest": "30.3.0",
    "npm-check-updates": "20.0.0",
    "prettier": "3.8.1",
    "prisma": "7.7.0",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.1"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "engines": {
    "node": "24.13.1"
  }
}
